# SmartPark Entry/Exit System - Environment Configuration

# Database Configuration
DATABASE_URL=sqlite:///./smartpark_entry_exit.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/smartpark

# System Configuration
TOTAL_PARKING_SLOTS=3
DEBUG=true

# API Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration (Frontend URLs)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Arduino/Serial Configuration
ARDUINO_PORT=COM3
# For Linux/Mac: ARDUINO_PORT=/dev/ttyUSB0
BAUD_RATE=9600

# Serial Bridge Configuration
BRIDGE_URL=http://localhost:5000
RECONNECT_DELAY=5.0
HEARTBEAT_TIMEOUT=60.0

# AI/ML Configuration
AI_MODEL_PATH=occupancy_model.pkl
ENABLE_AI_PREDICTIONS=true
MIN_TRAINING_SAMPLES=24

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=smartpark_entry_exit.log

# Feature Flags
ENABLE_WEBSOCKET=true
ENABLE_REAL_TIME_UPDATES=true
ENABLE_AUTO_GATE_CLOSE=true
AUTO_GATE_CLOSE_DELAY=5000

# Development Settings
MOCK_ARDUINO=false
SIMULATE_EVENTS=false
